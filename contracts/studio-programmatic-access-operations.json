    {
      "operationId": "workflows.get",
      "method": "GET",
      "path": "/api/v1/projects/{projectId}/workflows/{workflowId}",
      "requestLocation": "query",
      "querySchema": {
        "$schema": "https://json-schema.org/draft/2020-12/schema",
        "if": {
          "properties": {
            "view": {
              "const": "node"
            }
          },
          "required": [
            "view"
          ]
        },
        "properties": {
          "nodeName": {
            "type": "string"
          },
          "view": {
            "default": "full",
            "enum": [
              "meta",
              "full",
              "graph",
              "node"
            ],
            "type": "string"
          }
        },
        "then": {
          "properties": {
            "nodeName": {
              "minLength": 1
            }
          },
          "required": [
            "nodeName"
          ]
        },
        "type": "object"
      },
      "wrapperTier": "read",
      "effectiveTier": {
        "tier": "authorship",
        "when": "view is omitted (defaults to full), full, or node because the response includes definition JSON"
      },
      "successStatus": 200,
      "pagination": null,
      "stableErrorCodes": []
    },
