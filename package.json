{
  "name": "robotic-workflows-mcp-server",
  "version": "0.1.0",
  "private": true,
  "description": "MCP server for Automat robotic (RPA) workflows — lets AI agents build, deploy and manage workflows the way humans do in the studio.",
  "type": "module",
  "engines": {
    "node": ">=22 <25",
    "npm": "11.6.0"
  },
  "packageManager": "npm@11.6.0",
  "scripts": {
    "dev": "vercel dev",
    "deploy": "vercel --prod",
    "typecheck": "tsc --noEmit",
    "lint": "biome lint .",
    "format:check": "biome format .",
    "fix": "biome check --write .",
    "test": "npm run test:unit && npm run test:contract && npm run test:protocol",
    "test:unit": "vitest run tests/unit",
    "test:contract": "vitest run tests/contract",
    "test:protocol": "vitest run tests/protocol",
    "test:coverage": "vitest run --coverage",
    "verify": "npm run typecheck && npm run lint && npm run format:check && npm run test:coverage",
    "inspector": "mcp-inspector"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.26.0",
    "@upstash/redis": "^1.34.3",
    "mcp-handler": "1.1.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.5",
    "@modelcontextprotocol/inspector": "1.0.0",
    "@types/node": "22.19.21",
    "@vitest/coverage-v8": "4.1.10",
    "tsx": "4.23.1",
    "typescript": "5.9.3",
    "vercel": "54.13.0",
    "vitest": "4.1.10"
  }
}
