# Required Studio origin. Personal access tokens are supplied by each MCP
# client and forwarded to this origin; no shared MCP credential is configured.
STUDIO_API_BASE_URL=https://studio.runautomat.com

# Optional project and Doppler defaults. Connections can override the project
# with set_project, ?project_id=, or x-project-id.
STUDIO_DEFAULT_PROJECT_ID=
STUDIO_DOPPLER_PROJECT=
STUDIO_DOPPLER_CONFIG=

# Required in serverless deployments if set_project should persist across
# instances. The local test/development fallback is process-local.
KV_REST_API_URL=
KV_REST_API_TOKEN=

# Set only when STUDIO_API_BASE_URL points to a protected Vercel preview.
VERCEL_AUTOMATION_BYPASS_SECRET=
